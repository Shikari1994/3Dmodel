# Скопируй этот файл в .env и заполни своими значениями
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site3d_db
DB_USER=site3d_user
DB_PASSWORD=your_password_here

# Секретный ключ для JWT — придумай любую длинную строку
JWT_SECRET=change_this_to_a_long_random_string

# Порт на котором запустится сервер
PORT=3000

# Откуда разрешать запросы (твой GitHub Pages адрес)
CORS_ORIGIN=https://shikari1994.github.io
